# Ignore all compiled python files
__pycache__/
*.pyc

# Ignore large files globally
*.zip
*.log
.DS_Store

# Ignore any database, csv, weights, and npy files globally
*.h5
*.npy
*.csv

# Ignore 2D and temporary datasets/outputs
dataset/
dataset_clean/
dataset_skel/
dataset_split/
data_clean/
eval_outputs/
gradcam_outputs/
notebooks/
docs/
data/*
dataset_1d/
dataset_1d_heartbreaker/

# Exclude metadata and model weights from ignore rules
!data/subset_metadata_2000.csv
!data/subset_multiclass_metadata.csv
!data/clinical_features.csv
!models/binary_1d_ecg_model.h5
!models/binary_1d_ecg_model_fold*.h5
!models/multiclass_1d_ecg_model.h5
!models/clean_oof_ecg_probs.npy
!models/clean_oof_multiclass_probs.npy
!models/lightgbm_oof_multiclass_probs.npy

# Exclude text result files in models from ignore rules
!models/1d_model_results.txt
!models/heartbreaker_results.txt
!models/stress_test_results.txt
!models/multiclass_results.txt
!models/lightgbm_multiclass_results.txt
!models/lightgbm_feature_importances.json
!models/multiclass_thresholds*.json

# Committed demo cohort (small) so the MVP runs on a fresh clone / Streamlit Cloud
!data/raw/
!data/raw/**
!data/unseen_demo_metadata.csv
!data/scp_statements.csv

# Kept ignored on purpose (large / not needed at runtime):
#   data/Imagenes eco/        teammate's ~1.8GB raw-signal + 2D-image dump (source pool)
#   data/Imagenes eco.zip     covered by *.zip
#   data/ptbxl_database.csv   7MB index, only used by build_demo_cohort.py, covered by *.csv

# Re-exclude macOS junk even inside the whitelisted data/raw tree
**/.DS_Store
